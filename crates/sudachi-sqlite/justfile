# justfile - sudachi-sqlite
# Sudachi Japanese tokenizer for SQLite FTS5 full-text search

# Default recipe - show available commands
default:
    @just --list

# ============================================================================
# Environment
# ============================================================================

# Auto-discover Sudachi dictionary
export SUDACHI_DICT_PATH := env_var_or_default("SUDACHI_DICT_PATH", `find ~/.sudachi -name "system_full.dic" 2>/dev/null | head -1 || find ~/.sudachi -name "system_small.dic" 2>/dev/null | head -1 || echo ""`)

# Extension install path
EXTENSION_PATH := home_directory() / ".local/lib/libsudachi_sqlite.dylib"

# ============================================================================
# Build
# ============================================================================

# Build extension (release)
build:
    cargo build --release

# Build extension (dev)
build-dev:
    cargo build

# Check compilation
check:
    cargo check

# ============================================================================
# Install
# ============================================================================

# Install extension to ~/.local/lib/
install: build
    @mkdir -p ~/.local/lib
    cp target/release/libsudachi_sqlite.dylib ~/.local/lib/
    @echo "Installed to ~/.local/lib/libsudachi_sqlite.dylib"

# Uninstall extension
uninstall:
    rm -f ~/.local/lib/libsudachi_sqlite.dylib
    @echo "Removed ~/.local/lib/libsudachi_sqlite.dylib"

# ============================================================================
# Testing
# ============================================================================

# Run tests (requires dictionary)
test:
    @if [ -z "$SUDACHI_DICT_PATH" ] || [ ! -f "$SUDACHI_DICT_PATH" ]; then \
        echo "ERROR: SUDACHI_DICT_PATH not set or dictionary not found"; \
        echo "Run: just dict-setup"; \
        exit 1; \
    fi
    cargo test

# Run tests with output
test-verbose:
    cargo test -- --nocapture

# Interactive SQLite test
test-sqlite: install
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Testing sudachi_tokenizer in SQLite..."
    sqlite3 :memory: ".load ~/.local/lib/libsudachi_sqlite sudachi_fts5_tokenizer_init" \
        "CREATE VIRTUAL TABLE docs USING fts5(content, tokenize='sudachi_tokenizer');" \
        "INSERT INTO docs VALUES ('東京都立大学で研究');" \
        "SELECT '=== Searching for 大学 ===' as info;" \
        "SELECT * FROM docs WHERE docs MATCH '大学';" \
        "SELECT '=== Searching for 東京 ===' as info;" \
        "SELECT * FROM docs WHERE docs MATCH '東京';" \
        "SELECT '=== Success! B+C multi-granularity working ===' as result;"

# ============================================================================
# Code Quality
# ============================================================================

# Format code
fmt:
    cargo fmt

# Run clippy linter
lint:
    cargo clippy -- -D warnings

# Format and lint
fix: fmt lint

# ============================================================================
# Dictionary Setup
# ============================================================================

# Download and setup Sudachi dictionary
dict-setup:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p ~/.sudachi
    if [ ! -d ~/.sudachi/sudachi-dictionary-* ]; then
        echo "Downloading Sudachi dictionary..."
        curl -L https://github.com/WorksApplications/SudachiDict/releases/download/v20251022/sudachi-dictionary-20251022-full.zip -o /tmp/sudachi-dict.zip
        unzip -o /tmp/sudachi-dict.zip -d ~/.sudachi/
        rm /tmp/sudachi-dict.zip
        echo "Dictionary installed to ~/.sudachi/"
    else
        echo "Dictionary already exists at ~/.sudachi/"
    fi

# Show dictionary path
dict-path:
    @echo "SUDACHI_DICT_PATH: ${SUDACHI_DICT_PATH:-not found}"

# ============================================================================
# Utilities
# ============================================================================

# Show environment and paths
env:
    @echo "SUDACHI_DICT_PATH: ${SUDACHI_DICT_PATH:-not set}"
    @echo "EXTENSION_PATH: {{ EXTENSION_PATH }}"
    @echo "PWD: $(pwd)"
    @ls -la ~/.local/lib/libsudachi_sqlite.dylib 2>/dev/null || echo "Extension not installed"

# Clean build artifacts
clean:
    cargo clean

# Watch and rebuild on changes
watch:
    cargo watch -x check

# Full rebuild and install
rebuild: clean build install
    @echo "Rebuilt and reinstalled extension"
